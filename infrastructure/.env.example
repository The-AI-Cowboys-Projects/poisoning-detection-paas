# =============================================================================
# LLM Data Poisoning Detection PaaS — Environment Variable Template
# =============================================================================
# Copy this file to .env and populate every value marked CHANGE_ME.
# NEVER commit a populated .env file to source control.
#
#   cp infrastructure/.env.example infrastructure/.env
#
# Variable naming conventions:
#   DB_*        — database connection settings
#   KAFKA_*     — Kafka broker / topic settings
#   JWT_*       — authentication token settings
#   VECTOR_*    — embedding anomaly detector thresholds
#   MCP_*       — MCP tool schema auditor thresholds
#   TENANT_*    — multi-tenant rate limit configuration
# =============================================================================


# ---------------------------------------------------------------------------
# Application metadata
# ---------------------------------------------------------------------------
ENVIRONMENT=development
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Expose the API on this host port (Docker)
API_HOST_PORT=8000
# Expose the frontend on this host port (Docker)
FRONTEND_HOST_PORT=3000
# URL the browser uses to call the API (must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000


# ---------------------------------------------------------------------------
# PostgreSQL 16
# ---------------------------------------------------------------------------
POSTGRES_DB=poisoning_detection
POSTGRES_USER=paas_user
# CHANGE_ME — use a strong random password in all environments
POSTGRES_PASSWORD=CHANGE_ME_strong_pg_password
# Expose Postgres on this host port (set to empty to disable host binding)
POSTGRES_HOST_PORT=5432

# SQLAlchemy DSN used by the backend (asyncpg dialect)
# When running inside Docker, the hostname is the service name "postgres".
# For local development outside Docker, use "localhost".
DATABASE_URL=postgresql+asyncpg://paas_user:CHANGE_ME_strong_pg_password@postgres:5432/poisoning_detection

# Connection pool settings
DB_POSTGRES_POOL_SIZE=10
DB_POSTGRES_MAX_OVERFLOW=20
DB_POSTGRES_POOL_TIMEOUT=30
DB_POSTGRES_POOL_RECYCLE=1800


# ---------------------------------------------------------------------------
# Redis 7
# ---------------------------------------------------------------------------
# CHANGE_ME — use a strong random password
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=256mb

# Full DSN used by the backend
# auth is embedded: redis://:PASSWORD@HOST:PORT/DB_INDEX
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

DB_REDIS_MAX_CONNECTIONS=50
DB_REDIS_SOCKET_TIMEOUT=5.0
DB_REDIS_SOCKET_CONNECT_TIMEOUT=2.0


# ---------------------------------------------------------------------------
# Neo4j 5 — provenance lineage graph
# ---------------------------------------------------------------------------
NEO4J_USER=neo4j
# CHANGE_ME — must be at least 8 characters for Neo4j 5
NEO4J_PASSWORD=CHANGE_ME_strong_neo4j_password
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# DSN used by the backend (bolt protocol)
NEO4J_URI=bolt://neo4j:7687

# JVM heap settings (tune for available memory)
NEO4J_HEAP_INIT=256m
NEO4J_HEAP_MAX=512m
NEO4J_PAGE_CACHE=256m

DB_NEO4J_DATABASE=poisoning
DB_NEO4J_MAX_CONNECTION_LIFETIME=3600
DB_NEO4J_MAX_CONNECTION_POOL_SIZE=50


# ---------------------------------------------------------------------------
# Apache Kafka — KRaft mode (no Zookeeper)
# ---------------------------------------------------------------------------
# CHANGE_ME — generate with: python3 -c "import uuid, base64; print(base64.urlsafe_b64encode(uuid.uuid4().bytes).rstrip(b'=').decode())"
KAFKA_CLUSTER_ID=CHANGE_ME_generate_a_base64_uuid

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HOST_PORT=29092

# Topic names
KAFKA_SCAN_REQUESTS_TOPIC=scan-requests
KAFKA_SCAN_RESULTS_TOPIC=scan-results
KAFKA_AUDIT_EVENTS_TOPIC=audit-events

# Consumer group
KAFKA_CONSUMER_GROUP_ID=poisoning-detection-workers

# Partition count for new topics
KAFKA_NUM_PARTITIONS=3

# Log retention in hours (168 = 7 days)
KAFKA_LOG_RETENTION_HOURS=168

# Producer settings
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_COMPRESSION_TYPE=snappy
KAFKA_PRODUCER_MAX_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=5

# Consumer settings
KAFKA_CONSUMER_MAX_POLL_RECORDS=100
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false


# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# CHANGE_ME — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters.
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_48

JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30


# ---------------------------------------------------------------------------
# Vector Integrity Analyzer
# Cosine-dispersion anomaly detector for embedding poisoning detection
# ---------------------------------------------------------------------------
# Cosine similarity to cluster centroid below which a vector is flagged
VECTOR_COSINE_THRESHOLD=0.85
VECTOR_COSINE_SIMILARITY_THRESHOLD=0.85

# Z-score cutoff for dispersion-based outlier detection
VECTOR_DISPERSION_SIGMA=3.0

# Minimum clean-baseline vectors before emitting a definitive verdict
VECTOR_MIN_BASELINE_SAMPLES=100

# Hard cap on vectors per single API submission
VECTOR_MAX_VECTORS_PER_SUBMISSION=50000

# Acceptable embedding dimensions
VECTOR_EMBEDDING_DIMENSION_MIN=64
VECTOR_EMBEDDING_DIMENSION_MAX=8192


# ---------------------------------------------------------------------------
# MCP Tool Auditor
# Static analysis of MCP tool schemas for prompt-injection and exfiltration
# ---------------------------------------------------------------------------
# Descriptions longer than this character count are flagged
MCP_MAX_DESCRIPTION_LENGTH=2000

# Fraction of base64-looking tokens that triggers an exfiltration alert
MCP_BASE64_PATTERN_THRESHOLD=0.3

# Maximum JSON schema nesting depth before flagging complexity abuse
MCP_MAX_PARAMETER_DEPTH=5

# Schemas with more fields than this are flagged for review
MCP_MAX_SCHEMA_FIELDS=50


# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
API_RATE_LIMIT_PER_MINUTE=100

# Per-tier rate limits (requests per minute)
TENANT_FREE_TIER_RPM=10
TENANT_STARTER_TIER_RPM=100
TENANT_PROFESSIONAL_TIER_RPM=1000
TENANT_ENTERPRISE_TIER_RPM=10000

# API key configuration
TENANT_API_KEY_PREFIX_LENGTH=8
TENANT_API_KEY_TOTAL_LENGTH=48
TENANT_API_KEY_MAX_PER_TENANT=10

# Data isolation
TENANT_ROW_LEVEL_SECURITY_ENABLED=true
TENANT_CROSS_TENANT_QUERY_ALLOWED=false


# ---------------------------------------------------------------------------
# Optional: external integrations (leave blank to disable)
# ---------------------------------------------------------------------------
# Sentry error tracking DSN
SENTRY_DSN=

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=

# SMTP for alert notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
