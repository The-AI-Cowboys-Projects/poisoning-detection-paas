# =============================================================================
# LLM Data Poisoning Detection PaaS — Frontend Dockerfile (Next.js 14)
# =============================================================================
# Multi-stage build:
#   Stage 1 (deps):    Install node_modules with npm ci
#   Stage 2 (builder): Build Next.js in standalone output mode
#   Stage 3 (runner):  Production image; non-root user; standalone server
#
# Build args:
#   NODE_VERSION          — defaults to 20 (LTS)
#   NEXT_PUBLIC_API_URL   — baked into the build for client-side fetch
#
# Usage:
#   docker build -f infrastructure/Dockerfile.frontend \
#     --target runner \
#     --build-arg NEXT_PUBLIC_API_URL=https://api.yourdomain.com \
#     -t paas-frontend:latest .
# =============================================================================

ARG NODE_VERSION=20

# ---------------------------------------------------------------------------
# Stage 1: deps — install all node_modules (cached until package-lock changes)
# ---------------------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS deps

# Check https://github.com/nodejs/docker-node/tree/b4117f9333da4138b03a546ec926ef50a31506c3#nodealpine
# to understand why libc6-compat might be needed.
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy lockfile and manifests only — maximise cache hit rate
COPY frontend/package.json frontend/package-lock.json* ./

# ci install for reproducible, lockfile-exact dependency resolution
RUN npm ci --ignore-scripts

# ---------------------------------------------------------------------------
# Stage 2: builder — compile the Next.js application
# ---------------------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS builder

ARG NEXT_PUBLIC_API_URL=http://localhost:8000

WORKDIR /app

# Bring in installed node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy source code (build context is the project root)
COPY frontend/ .

# Inject public env vars — these are baked into the client bundle at build time
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Disable Next.js telemetry in CI / Docker builds
ENV NEXT_TELEMETRY_DISABLED=1

# Enable standalone output mode — generates a self-contained server in .next/standalone
# This must also be set in next.config.js: output: 'standalone'
ENV NEXT_PRIVATE_STANDALONE=1

RUN npm run build

# Verify the standalone directory was produced
RUN test -d .next/standalone || (echo "ERROR: .next/standalone missing. Add output: 'standalone' to next.config.js" && exit 1)

# ---------------------------------------------------------------------------
# Stage 3: runner — minimal production image
# ---------------------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS runner

LABEL org.opencontainers.image.title="LLM Poisoning Detection Dashboard"
LABEL org.opencontainers.image.description="Next.js 14 AI-SPM dashboard for LLM poisoning detection PaaS"
LABEL org.opencontainers.image.source="https://github.com/ai-cowboys/poisoning-detection-paas"

RUN apk add --no-cache \
    tini \
    curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 --ingroup nodejs nextjs

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME="0.0.0.0"

# Copy the standalone output and static assets
# Ownership set to nextjs:nodejs so the server can read its own files
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

HEALTHCHECK \
    --interval=15s \
    --timeout=10s \
    --start-period=20s \
    --retries=3 \
    CMD curl -fsSL http://localhost:3000/api/health || exit 1

# tini as PID 1 for clean signal forwarding / zombie reaping
ENTRYPOINT ["/sbin/tini", "--"]

# Next.js standalone server — server.js is generated by the standalone build
CMD ["node", "server.js"]
