# Node.js / Next.js
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# Next.js build output
frontend/.next/
frontend/out/

# Production build artefacts
frontend/build/

# next-env.d.ts is auto-generated
