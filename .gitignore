.npm
package-lock.json.bak

# Parcel
.parcel-cache/

# Rollup
.rollup.cache/

# ESBuild
.esbuild/

# Turbopack
.turbopack/

# TypeScript
*.tsbuildinfo

# Storybook
.storybook-out/
storybook-static/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Do not ignore Dockerfiles or docker-compose.yml —
# those are checked into source control.
.dockerignore

# Local override files
docker-compose.override.yml
docker-compose.local.yml

# ---------------------------------------------------------------------------
# Database / data stores
# ---------------------------------------------------------------------------

# PostgreSQL local data (if running locally via pg_ctl)
postgres_data/

# Redis dump
dump.rdb
*.rdb

# Neo4j local data
neo4j_data/
neo4j_logs/
neo4j_plugins/

# Kafka local data
kafka_data/
kafka-logs/

# SQLite (dev/test databases)
*.db
*.sqlite
*.sqlite3

# Alembic
# (keep alembic/ directory tracked; only ignore generated artefacts)
backend/alembic/versions/.DS_Store

